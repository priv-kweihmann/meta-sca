From 7ab6993de0f7804c695d4116aa72fc81e90460f3 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Robert-Andr=C3=A9=20Mauchin?=
 <30413512+eclipseo@users.noreply.github.com>
Date: Sun, 15 Oct 2023 14:37:55 +0200
Subject: [PATCH] Depends on tomli instead of deprecated toml
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Signed-off-by: Robert-André Mauchin <zebob.m@gmail.com>
Upstream-Status: Submitted [https://github.com/aboutcode-org/dparse2/pull/7]
---
 dparse2/parser.py   | 6 +++---
 setup.py            | 2 +-
 tests/test_parse.py | 2 +-
 3 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/dparse2/parser.py b/dparse2/parser.py
index 0cef9ec..a930866 100644
--- a/dparse2/parser.py
+++ b/dparse2/parser.py
@@ -11,7 +11,7 @@
 from configparser import NoOptionError
 from io import StringIO
 
-import toml
+import tomli
 import yaml
 
 from packvers.requirements import InvalidRequirement
@@ -158,7 +158,7 @@ def parse(self):
         Parse a Pipfile (as seen in pipenv)
         """
         try:
-            data = toml.loads(self.obj.content, _dict=OrderedDict)
+            data = tomli.loads(self.obj.content, _dict=OrderedDict)
             if not data:
                 return
             for package_type in ["packages", "dev-packages"]:
@@ -181,7 +181,7 @@ def parse(self):
                             section=package_type,
                         )
                     )
-        except (toml.TomlDecodeError, IndexError):
+        except (tomli.TomlDecodeError, IndexError):
             pass
 
 
diff --git a/setup.py b/setup.py
index ab7f7e1..20dcd40 100644
--- a/setup.py
+++ b/setup.py
@@ -25,7 +25,7 @@
     install_requires=[
         "packvers",
         "pyyaml",
-        "toml",
+        "tomli",
     ],
     license="MIT",
     zip_safe=False,
diff --git a/tests/test_parse.py b/tests/test_parse.py
index a20d4e9..920ee24 100644
--- a/tests/test_parse.py
+++ b/tests/test_parse.py
@@ -93,7 +93,7 @@ def test_pipfile():
 
 [dev-packages]
 
-toml = "*"
+tomli = "*"
 """
     dep_file = parse(content, file_name="Pipfile")
     assert len(dep_file.dependencies) == 4
